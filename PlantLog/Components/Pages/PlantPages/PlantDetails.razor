@page "/plant-details/{Id}"
@rendermode InteractiveServer
@using PlantLog.PlantModels.Entities
@using PlantLog.Services
@inject PlantService PlantService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container mt-4 mb-5">
    @if (plant == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-success" role="status"></div>
            <p>Növény adatainak betöltése a MongoDB-ből...</p>
        </div>
    }
    else
    {
        @* --- FEJLÉC ÉS ALAPADATOK --- *@
        <div class="row rounded bg-white shadow-sm p-4 mb-4 border-top border-success border-5">
            <div class="col-md-4 text-center">
                <img src="@mainImageBase64" class="img-fluid rounded shadow border" style="max-height: 350px; object-fit: cover;" alt="@plant.Nickname" />
            </div>
            <div class="col-md-8">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1 class="text-success display-5 fw-bold">@plant.Nickname</h1>
                        <p class="lead text-muted">@plant.SpeciesId</p>
                    </div>
                    <span class="badge bg-success p-2">Aktív</span>
                </div>

                <hr />

                <div class="row mt-3">
                    <div class="col-6">
                        <p><strong>📍 Helyszín:</strong> <span class="text-secondary">@plant.Location</span></p>
                        <p><strong>📅 Regisztrálva:</strong> <span class="text-secondary">@plant.History.FirstOrDefault()?.Date.ToString("yyyy.MM.dd")</span></p>
                    </div>
                    <div class="col-6">
                        <p><strong>💧 Öntözési gyakoriság:</strong> <span class="text-secondary">@plant.WateringFrequency naponta</span></p>
                        <p><strong>⏱ Utoljára öntözve:</strong> <span class="text-primary fw-bold">@plant.LastWatered.ToString("g")</span></p>
                    </div>
                </div>

                @* --- MŰVELETI GOMBOK --- *@
                <div class="d-flex gap-2 mt-4 pt-3 border-top">
                    <button class="btn btn-primary btn-lg" @onclick="WaterPlantQuick">
                        <i class="bi bi-droplet-fill"></i> Gyors Öntözés
                    </button>
                    <button class="btn btn-outline-danger" @onclick="ConfirmDelete">
                        <i class="bi bi-trash"></i> Növény Törlése
                    </button>
                    <a href="/my-plants" class="btn btn-outline-secondary ms-auto">Vissza a listához</a>
                </div>
            </div>
        </div>

        @* --- ÚJ BEJEGYZÉS LÉTREHOZÁSA --- *@
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header bg-dark text-white fw-bold">
                <i class="bi bi-plus-circle-fill me-2">
                </i>Új esemény vagy állapot rögzítése az idővonalon
            </div>
            <div class="card-body bg-light">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted">Esemény típusa</label>
                        <select @bind="newLogAction" class="form-select">
                            <option value="Általános">Általános megjegyzés</option>
                            <option value="Öntözés">Öntözés</option>
                            <option value="Tápoldatozás">Tápoldatozás</option>
                            <option value="Átültetés">Átültetés</option>
                            <option value="Metszés">Metszés</option>
                            <option value="Növekedés">Növekedés észlelése</option>
                            <option value="Betegség/Kártevő">Betegség/Kártevő</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted">Részletes leírás / Megjegyzés</label>
                        <input type="text" @bind="newLogNote" class="form-control" placeholder="Mi történt? (pl. Új hajtás jelent meg, kevesebb vizet kapott...)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted">Kép csatolása (opcionális)</label>
                        <InputFile OnChange="OnLogFileChange" class="form-control" accept="image/*" />
                    </div>
                    <div class="col-12 text-end mt-3">
                        @if (isSavingLog)
                        {
                            <button class="btn btn-success" disabled>
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Mentés folyamatban...
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success px-5" @onclick="SaveComplexLogEntry">
                                <i class="bi bi-save me-2"></i> Bejegyzés Rögzítése
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* --- IDŐVONAL / NAPLÓ TÁBLÁZAT --- *@
        <div class="bg-white rounded shadow-sm p-4">
            <h4 class="text-success mb-4"><i class="bi bi-clock-history me-2"></i> Gondozási Idővonal és Galéria</h4>

            @if (plant.History == null || !plant.History.Any())
            {
                <div class="alert alert-info text-center">Még nincsenek bejegyzések ehhez a növényhez.</div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th style="width: 15%">Dátum</th>
                            <th style="width: 10%">Fotó</th>
                            <th style="width: 20%">Esemény</th>
                            <th style="width: 55%">Megjegyzés</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in plant.History.OrderByDescending(l => l.Date))
                        {
                            <tr>
                                <td class="text-secondary small">
                                    @log.Date.ToString("yyyy.MM.dd.")<br />
                                    <span class="fw-bold text-dark">@log.Date.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.ImageId))
                                    {
                                        @if (loadedLogImages.ContainsKey(log.ImageId))
                                        {
                                            <img src="@loadedLogImages[log.ImageId]"
                                                 style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;"
                                                 class="rounded border shadow-sm hover-zoom"
                                                 @onclick="() => OpenLightbox(log.ImageId)"
                                                 title="Kattints a nagyításhoz" />
                                        }
                                        else
                                        {
                                            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>Nincs kép</em></span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetBadgeClass(log.Action) p-2 text-uppercase small">
                                        @log.Action
                                    </span>
                                </td>
                                <td class="text-dark">@log.Note</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@* --- LIGHTBOX / MODÁLIS ABLAK KÉP NAGYÍTÁSHOZ --- *@
@if (isLightboxOpen)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.85);" tabindex="-1" @onclick="CloseLightbox">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-body text-center p-0 position-relative">
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" @onclick="CloseLightbox"></button>
                    <img src="@currentLightboxImage" class="img-fluid rounded shadow-lg" style="max-height: 90vh;" @onclick:stopPropagation />
                </div>
            </div>
        </div>
    </div>
}

@* CSS stílus a kép nagyítás effektushoz *@
<style>
    .hover-zoom:hover {
        transform: scale(1.1);
        transition: transform 0.2s;
        z-index: 10;
    }
</style>

@code {
    [Parameter] public string Id { get; set; } = "";
    private Plant? plant;
    private string mainImageBase64 = "/images/no-image.png"; // Alapértelmezett, ha nincs profilkép

    // Új bejegyzés mezői
    private string newLogAction = "Általános";
    private string newLogNote = "";
    private IBrowserFile? attachedFile;
    private bool isSavingLog = false;

    // Képkezelés
    private Dictionary<string, string> loadedLogImages = new(); // Gyorsítótár a naplóképeknek

    // Lightbox állapot
    private bool isLightboxOpen = false;
    private string currentLightboxImage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCompletePlantData();
    }

    private async Task LoadCompletePlantData()
    {
        // 1. Növény lekérése ID alapján
        plant = await PlantService.GetPlantByIdAsync(Id);

        if (plant != null)
        {
            // 2. Fő profilkép betöltése
            if (!string.IsNullOrEmpty(plant.ImageId))
            {
                mainImageBase64 = await PlantService.GetPlantImageBase64Async(plant.ImageId);
            }

            // 3. Naplóbejegyzések képeinek aszinkron betöltése (ha még nincsenek a szótárban)
            if (plant.History != null)
            {
                foreach (var log in plant.History.Where(l => !string.IsNullOrEmpty(l.ImageId)))
                {
                    // Csak akkor töltjük le, ha még nincs meg a memóriában
                    if (!loadedLogImages.ContainsKey(log.ImageId!))
                    {
                        // Háttérben indul a letöltés, nem blokkolja a renderelést
                        _ = LoadLogImageAsync(log.ImageId!);
                    }
                }
            }
        }
    }

    // Segédmetódus egyetlen naplókép háttérben való letöltéséhez
    private async Task LoadLogImageAsync(string imageId)
    {
        try
        {
            var base64 = await PlantService.GetPlantImageBase64Async(imageId);
            loadedLogImages[imageId] = base64;
            await InvokeAsync(StateHasChanged); // Frissítjük a UI-t, ha megjött a kép
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hiba a naplókép ({imageId}) betöltésekor: {ex.Message}");
            loadedLogImages[imageId] = "/images/image-error.png"; // Hiba jelzése a UI-n
        }
    }

    // Fájl kiválasztás esemény
    private void OnLogFileChange(InputFileChangeEventArgs e)
    {
        attachedFile = e.File;
    }

    // Komplex naplóbejegyzés mentése (szöveg + opcionális kép)
    private async Task SaveComplexLogEntry()
    {
        if (plant == null || string.IsNullOrWhiteSpace(newLogNote)) return;

        isSavingLog = true;
        try
        {
            Stream? imageStream = null;
            string? fileName = null;

            // Ha csatoltak fájlt, megnyitjuk a stream-et
            if (attachedFile != null)
            {
                imageStream = attachedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 15); // Max 15MB
                fileName = attachedFile.Name;
            }

            // Meghívjuk az új, kombinált szerviz metódust
            await PlantService.AddLogWithImageAsync(plant.Id, newLogAction, newLogNote, imageStream, fileName);

            // Űrlap alaphelyzetbe állítása
            newLogAction = "Általános";
            newLogNote = "";
            attachedFile = null;

            // Adatok újratöltése
            await LoadCompletePlantData();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Hiba a mentés során: {ex.Message}");
        }
        finally
        {
            isSavingLog = false;
        }
    }

    // Gyors öntözés gomb logikája (képernyő frissítéssel)
    private async Task WaterPlantQuick()
    {
        if (plant != null)
        {
            await PlantService.AddLogEntryAsync(plant.Id, "Öntözés", "Gyors rögzítés a Műveletek gombbal.");
            await LoadCompletePlantData(); // Teljes újratöltés
        }
    }

    // Törlés megerősítése
    private async Task ConfirmDelete()
    {
        if (plant == null) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", new[] { $"BIZTOSAN törölni akarod a(z) '{plant.Nickname}' nevű növényt a teljes történetével és képeivel együtt?\nEz a művelet nem vonható vissza!" });

        if (confirmed)
        {
            await PlantService.DeletePlantAsync(plant.Id, plant.ImageId);
            Nav.NavigateTo("/my-plants");
        }
    }

    // Lightbox kezelése
    private void OpenLightbox(string imageId)
    {
        if (loadedLogImages.ContainsKey(imageId))
        {
            currentLightboxImage = loadedLogImages[imageId];
            isLightboxOpen = true;
        }
    }

    private void CloseLightbox()
    {
        isLightboxOpen = false;
        currentLightboxImage = "";
    }

    // Bootstrap osztályok rendelése az esemény típusához
    private string GetBadgeClass(string action)
    {
        return action switch
        {
            "Öntözés" => "bg-primary text-white",
            "Átültetés" => "bg-warning text-dark",
            "Tápoldatozás" => "bg-info text-dark",
            "Betegség/Kártevő" => "bg-danger text-white",
            "Növekedés" => "bg-success text-white",
            "Metszés" => "bg-secondary text-white",
            _ => "bg-light text-dark border"
        };
    }
}